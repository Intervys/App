# ── Port exposé (défaut : 80) ──
PORT=80

# ── Sécurité mailer (token partagé entre PocketBase hooks et le service mailer) ──
MAILER_SECRET=change-this-random-secret

# ── Compte superadmin PocketBase (premier démarrage uniquement) ──
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-this-password
